title: $:/plugins/rimir/appify/ui/tab-button
type: text/vnd.tiddlywiki

\parameters(stateTiddler, value, default, label)
<$button class="appify-tab-btn" set=<<stateTiddler>> setTo=<<value>>>
<$reveal stateTitle=<<stateTiddler>> type="match" text=<<value>> default=<<default>>>
<span class="appify-tab-active"><<label>></span>
</$reveal>
<$reveal stateTitle=<<stateTiddler>> type="nomatch" text=<<value>> default=<<default>>>
<<label>>
</$reveal>
</$button>
