title: $:/plugins/rimir/appify/ui/tab-button
type: text/vnd.tiddlywiki

\parameters(setTiddler, value, activeValue, label)
<$button class="appify-tab-btn" set=<<setTiddler>> setTo=<<value>>>
<$list filter="[<activeValue>match<value>]" variable="__x__">
<span class="appify-tab-active"><<label>></span>
</$list>
<$list filter="[<activeValue>!match<value>]" variable="__x__">
<<label>>
</$list>
</$button>
